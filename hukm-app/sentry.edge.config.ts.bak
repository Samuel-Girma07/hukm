/**
 * HUKM — Sentry edge runtime config (middleware, edge route handlers).
 *
 * We don't currently run anything on the edge runtime, but this file
 * has to exist for `@sentry/nextjs` to wire up the edge bundle. No-op
 * when SENTRY_DSN is unset.
 */

import * as Sentry from "@sentry/nextjs";

const dsn = process.env.SENTRY_DSN;

if (dsn && dsn.trim().length > 0) {
  Sentry.init({
    dsn,
    tracesSampleRate: 0.1,
    debug: false,
    enabled: process.env.NODE_ENV === "production",
  });
}

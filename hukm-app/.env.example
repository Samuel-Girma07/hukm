# NVIDIA API key (used for both /v1/embeddings and /v1/chat/completions)
NVIDIA_API_KEY=nvapi-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-side ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional: Redis URL for distributed rate limiting (falls back to in-memory)
# REDIS_URL=redis://localhost:6379

# Optional: Sentry DSN. Leave unset to disable Sentry entirely.
# SENTRY_DSN=https://...@sentry.io/...

# Required for /admin. Stored as plaintext in env; the page hashes it client-side
# and compares against the SHA-256 of this value.
ADMIN_PASSWORD=please-change-me

# Pino log level. One of: trace | debug | info | warn | error | fatal
PINO_LOG_LEVEL=info

# Public origin used to construct shareable URLs (e.g. https://hukm.vercel.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000

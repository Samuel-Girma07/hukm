# NVIDIA API Key - used for both chat completions and embeddings
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase Service Role Key - server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ---------- Optional production hardening ----------

# Pino log level (default: "info" in production, "debug" otherwise)
# HUKM_LOG_LEVEL=info

# Sentry error reporting (only enabled when DSN is set)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Redis-backed rate limiter (recommended for multi-instance deployments)
# REDIS_URL=redis://localhost:6379
